{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.la-muni-rag.invalid/v1/evidence-bundle.schema.json",
  "title": "EvidenceBundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "response_type",
    "product_boundary",
    "evidence_bundle_id",
    "tenant_id",
    "request_id",
    "query",
    "jurisdiction",
    "generated_at",
    "sources",
    "claims",
    "citations",
    "contradictions",
    "missing_evidence",
    "limitations",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "$ref": "common.schema.json#/$defs/SchemaVersion"
    },
    "response_type": {
      "const": "evidence_bundle"
    },
    "product_boundary": {
      "const": "evidence_and_procedure_only"
    },
    "evidence_bundle_id": {
      "$ref": "common.schema.json#/$defs/Uuid"
    },
    "tenant_id": {
      "$ref": "common.schema.json#/$defs/Uuid"
    },
    "request_id": {
      "$ref": "common.schema.json#/$defs/Uuid"
    },
    "query": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "jurisdiction": {
      "$ref": "common.schema.json#/$defs/Jurisdiction"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/Source"
      },
      "uniqueItems": true
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/Claim"
      },
      "uniqueItems": true
    },
    "citations": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/Citation"
      },
      "uniqueItems": true
    },
    "contradictions": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/Contradiction"
      },
      "uniqueItems": true
    },
    "missing_evidence": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/MissingEvidence"
      },
      "uniqueItems": true
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      },
      "uniqueItems": true
    },
    "provenance": {
      "allOf": [
        {
          "$ref": "common.schema.json#/$defs/Provenance"
        },
        {
          "type": "object",
          "properties": {
            "source_product": {
              "const": "la_muni_rag"
            }
          }
        }
      ]
    }
  }
}
