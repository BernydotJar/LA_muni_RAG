{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.la-muni-rag.invalid/v1/procedure-list-response.schema.json",
  "title": "ProcedureListResponse v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "response_type", "request_id", "tenant_id", "items", "next_cursor", "provenance"],
  "properties": {
    "schema_version": { "$ref": "common.schema.json#/$defs/SchemaVersion" },
    "response_type": { "const": "procedure_catalog_page" },
    "request_id": { "$ref": "common.schema.json#/$defs/Uuid" },
    "tenant_id": { "$ref": "common.schema.json#/$defs/Uuid" },
    "items": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["procedure_id", "procedure_key", "title", "jurisdiction", "latest_version_number", "latest_lifecycle_status", "approved_workflow_version_id", "approved_version_number", "approval_state", "created_at", "updated_at"],
        "properties": {
          "procedure_id": { "$ref": "common.schema.json#/$defs/Uuid" },
          "procedure_key": { "type": "string", "minLength": 3, "maxLength": 128, "pattern": "^[a-z0-9][a-z0-9._:-]*$" },
          "title": { "type": "string", "minLength": 1, "maxLength": 300 },
          "jurisdiction": { "type": "string", "minLength": 1, "maxLength": 500 },
          "latest_version_number": { "type": ["integer", "null"], "minimum": 1 },
          "latest_lifecycle_status": { "type": ["string", "null"], "enum": ["draft", "in_review", "approved", "superseded", "archived", null] },
          "approved_workflow_version_id": { "oneOf": [{ "$ref": "common.schema.json#/$defs/Uuid" }, { "type": "null" }] },
          "approved_version_number": { "type": ["integer", "null"], "minimum": 1 },
          "approval_state": { "type": "string", "enum": ["approved", "unapproved"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        },
        "allOf": [{
          "if": { "properties": { "approval_state": { "const": "approved" } }, "required": ["approval_state"] },
          "then": { "properties": { "approved_workflow_version_id": { "$ref": "common.schema.json#/$defs/Uuid" }, "approved_version_number": { "type": "integer", "minimum": 1 } } },
          "else": { "properties": { "approved_workflow_version_id": { "type": "null" }, "approved_version_number": { "type": "null" } } }
        }]
      }
    },
    "next_cursor": { "type": ["string", "null"], "minLength": 1, "maxLength": 512, "pattern": "^[A-Za-z0-9_-]+$" },
    "provenance": { "$ref": "common.schema.json#/$defs/Provenance" }
  }
}
