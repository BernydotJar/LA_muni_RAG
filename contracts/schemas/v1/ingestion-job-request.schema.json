{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.la-muni-rag.invalid/v1/ingestion-job-request.schema.json",
  "title": "IngestionJobRequest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "tenant_id",
    "pipeline_profile",
    "document_version_id",
    "artifact_sha256"
  ],
  "properties": {
    "schema_version": {
      "$ref": "common.schema.json#/$defs/SchemaVersion"
    },
    "request_id": {
      "$ref": "common.schema.json#/$defs/Uuid"
    },
    "tenant_id": {
      "$ref": "common.schema.json#/$defs/Uuid"
    },
    "pipeline_profile": {
      "const": "municipal_document_v1"
    },
    "document_version_id": {
      "$ref": "common.schema.json#/$defs/Uuid"
    },
    "artifact_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
