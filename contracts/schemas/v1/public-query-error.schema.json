{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.la-muni-rag.invalid/v1/public-query-error.schema.json",
  "title": "PublicQueryError v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "response_type", "request_id", "error"],
  "properties": {
    "schema_version": { "$ref": "common.schema.json#/$defs/SchemaVersion" },
    "response_type": { "const": "public_error" },
    "request_id": { "$ref": "common.schema.json#/$defs/Uuid" },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "invalid_request", "forbidden", "method_not_allowed",
            "rate_limit_exceeded", "service_unavailable", "internal_error"
          ]
        },
        "message": { "type": "string", "minLength": 1, "maxLength": 200 },
        "retryable": { "type": "boolean" }
      }
    }
  }
}
