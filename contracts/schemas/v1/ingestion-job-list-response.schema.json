{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.la-muni-rag.invalid/v1/ingestion-job-list-response.schema.json",
  "title": "IngestionJobListResponse v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "response_type", "request_id", "tenant_id", "items", "next_cursor", "provenance"],
  "properties": {
    "schema_version": { "$ref": "common.schema.json#/$defs/SchemaVersion" },
    "response_type": { "const": "ingestion_job_catalog_page" },
    "request_id": { "$ref": "common.schema.json#/$defs/Uuid" },
    "tenant_id": { "$ref": "common.schema.json#/$defs/Uuid" },
    "items": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["job_id", "document_version_id", "status", "attempt_count", "max_attempts", "available_at", "started_at", "finished_at", "last_error_code", "last_error_retryable", "created_at", "updated_at"],
        "properties": {
          "job_id": { "$ref": "common.schema.json#/$defs/Uuid" },
          "document_version_id": { "$ref": "common.schema.json#/$defs/Uuid" },
          "status": { "type": "string", "enum": ["queued", "processing", "retry_wait", "processed", "failed", "cancelled", "superseded"] },
          "attempt_count": { "type": "integer", "minimum": 0, "maximum": 10 },
          "max_attempts": { "type": "integer", "minimum": 1, "maximum": 10 },
          "available_at": { "type": "string", "format": "date-time" },
          "started_at": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
          "finished_at": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
          "last_error_code": { "type": ["string", "null"], "pattern": "^[a-z][a-z0-9_]{0,63}$" },
          "last_error_retryable": { "type": ["boolean", "null"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "next_cursor": { "type": ["string", "null"], "minLength": 1, "maxLength": 512, "pattern": "^[A-Za-z0-9_-]+$" },
    "provenance": { "$ref": "common.schema.json#/$defs/Provenance" }
  }
}
