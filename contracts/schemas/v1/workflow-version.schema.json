{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.la-muni-rag.invalid/v1/workflow-version.schema.json",
  "title": "WorkflowVersionV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "response_type",
    "request_id",
    "tenant_id",
    "procedure_id",
    "procedure_key",
    "workflow_version_id",
    "version_number",
    "lifecycle_status",
    "generation_source",
    "revision",
    "title",
    "jurisdiction",
    "workflow_definition",
    "evidence_bundle_id",
    "submitted_by_principal_id",
    "submitted_at",
    "latest_review",
    "approval",
    "superseded_by_workflow_version_id",
    "archived_by_principal_id",
    "archived_at",
    "created_at",
    "updated_at",
    "limitations",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "response_type": {
      "const": "workflow_version"
    },
    "request_id": {
      "$ref": "common.schema.json#/$defs/Uuid"
    },
    "tenant_id": {
      "$ref": "common.schema.json#/$defs/Uuid"
    },
    "procedure_id": {
      "$ref": "common.schema.json#/$defs/Uuid"
    },
    "procedure_key": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "workflow_version_id": {
      "$ref": "common.schema.json#/$defs/Uuid"
    },
    "version_number": {
      "type": "integer",
      "minimum": 1
    },
    "lifecycle_status": {
      "type": "string",
      "enum": [
        "draft",
        "in_review",
        "approved",
        "superseded",
        "archived"
      ]
    },
    "generation_source": {
      "type": "string",
      "enum": [
        "ai",
        "human",
        "import"
      ]
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "jurisdiction": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "workflow_definition": {
      "$ref": "procedure-workflow.schema.json"
    },
    "evidence_bundle_id": {
      "anyOf": [
        {
          "$ref": "common.schema.json#/$defs/Uuid"
        },
        {
          "type": "null"
        }
      ]
    },
    "submitted_by_principal_id": {
      "anyOf": [
        {
          "$ref": "common.schema.json#/$defs/Uuid"
        },
        {
          "type": "null"
        }
      ]
    },
    "submitted_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "latest_review": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "review_id",
            "reviewer_principal_id",
            "decision",
            "notes",
            "created_at"
          ],
          "properties": {
            "review_id": {
              "$ref": "common.schema.json#/$defs/Uuid"
            },
            "reviewer_principal_id": {
              "$ref": "common.schema.json#/$defs/Uuid"
            },
            "decision": {
              "type": "string",
              "enum": [
                "changes_requested",
                "recommended_for_approval"
              ]
            },
            "notes": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4000
            },
            "created_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "approval": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "approval_id",
            "approver_principal_id",
            "decision",
            "notes",
            "created_at"
          ],
          "properties": {
            "approval_id": {
              "$ref": "common.schema.json#/$defs/Uuid"
            },
            "approver_principal_id": {
              "$ref": "common.schema.json#/$defs/Uuid"
            },
            "decision": {
              "const": "approved"
            },
            "notes": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4000
            },
            "created_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "superseded_by_workflow_version_id": {
      "anyOf": [
        {
          "$ref": "common.schema.json#/$defs/Uuid"
        },
        {
          "type": "null"
        }
      ]
    },
    "archived_by_principal_id": {
      "anyOf": [
        {
          "$ref": "common.schema.json#/$defs/Uuid"
        },
        {
          "type": "null"
        }
      ]
    },
    "archived_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "credential_id",
        "audit_id",
        "created_at"
      ],
      "properties": {
        "credential_id": {
          "$ref": "common.schema.json#/$defs/Uuid"
        },
        "audit_id": {
          "$ref": "common.schema.json#/$defs/Uuid"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
