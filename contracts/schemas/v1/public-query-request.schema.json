{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.la-muni-rag.invalid/v1/public-query-request.schema.json",
  "title": "PublicQueryRequest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["message", "mode", "limit"],
  "properties": {
    "message": { "type": "string", "minLength": 3, "maxLength": 1000 },
    "mode": { "type": "string", "enum": ["keyword", "phrase"] },
    "limit": { "type": "integer", "minimum": 1, "maximum": 5 }
  }
}
