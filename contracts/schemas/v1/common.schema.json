{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.la-muni-rag.invalid/v1/common.schema.json",
  "title": "LA Muni RAG integration contract common definitions",
  "$defs": {
    "Uuid": {
      "type": "string",
      "format": "uuid"
    },
    "SafeOpaqueId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "SchemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "SemVer": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "Jurisdiction": {
      "type": "string",
      "minLength": 2,
      "maxLength": 240
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "EvidenceStatus": {
      "type": "string",
      "enum": [
        "supported",
        "inferred_for_review",
        "comparative_reference",
        "missing_evidence",
        "not_applicable"
      ]
    },
    "AuthorityStatus": {
      "type": "string",
      "enum": [
        "official_target_jurisdiction",
        "official_national",
        "comparative",
        "contextual",
        "unknown"
      ]
    },
    "Provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_product",
        "generated_by",
        "created_at",
        "source_refs",
        "credential_id",
        "audit_id"
      ],
      "properties": {
        "source_product": {
          "type": "string",
          "enum": [
            "la_muni_rag",
            "os_electoral",
            "content_agency"
          ]
        },
        "generated_by": {
          "type": "string",
          "enum": [
            "ai",
            "human",
            "system",
            "integration_client",
            "import"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SafeOpaqueId"
          },
          "uniqueItems": true
        },
        "credential_id": {
          "$ref": "#/$defs/Uuid"
        },
        "audit_id": {
          "$ref": "#/$defs/Uuid"
        }
      }
    },
    "Source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "document_id",
        "document_version_id",
        "title",
        "source_jurisdiction",
        "target_jurisdiction",
        "authority_status",
        "official_source",
        "official_for_target_jurisdiction",
        "source_url",
        "content_sha256",
        "status",
        "limitations"
      ],
      "properties": {
        "source_id": {
          "$ref": "#/$defs/Uuid"
        },
        "document_id": {
          "$ref": "#/$defs/Uuid"
        },
        "document_version_id": {
          "$ref": "#/$defs/Uuid"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "municipality": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 160
        },
        "source_jurisdiction": {
          "$ref": "#/$defs/Jurisdiction"
        },
        "target_jurisdiction": {
          "$ref": "#/$defs/Jurisdiction"
        },
        "authority_status": {
          "$ref": "#/$defs/AuthorityStatus"
        },
        "official_source": {
          "type": "boolean"
        },
        "official_for_target_jurisdiction": {
          "type": "boolean"
        },
        "source_url": {
          "oneOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "content_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        },
        "status": {
          "type": "string",
          "enum": [
            "verified",
            "acquired",
            "ingested",
            "missing_source",
            "superseded"
          ]
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "const": "missing_source"
              }
            }
          },
          "else": {
            "type": "object",
            "properties": {
              "source_url": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        },
        {
          "if": {
            "type": "object",
            "required": [
              "municipality"
            ],
            "properties": {
              "municipality": {
                "const": "mixco"
              }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "authority_status": {
                "const": "comparative"
              },
              "official_source": {
                "const": true
              },
              "official_for_target_jurisdiction": {
                "const": false
              },
              "limitations": {
                "type": "array",
                "contains": {
                  "const": "Referencia comparativa de la Municipalidad de Mixco. No define por sí sola el procedimiento oficial de Antigua Guatemala."
                }
              }
            }
          }
        }
      ]
    },
    "Citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "citation_id",
        "source_id",
        "document_version_id",
        "section_id",
        "label",
        "excerpt",
        "source_url",
        "page_start",
        "page_end",
        "authority_status",
        "jurisdiction",
        "evidence_status"
      ],
      "properties": {
        "citation_id": {
          "$ref": "#/$defs/Uuid"
        },
        "source_id": {
          "$ref": "#/$defs/Uuid"
        },
        "document_version_id": {
          "$ref": "#/$defs/Uuid"
        },
        "section_id": {
          "$ref": "#/$defs/Uuid"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "excerpt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "page_start": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "page_end": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "authority_status": {
          "$ref": "#/$defs/AuthorityStatus"
        },
        "jurisdiction": {
          "$ref": "#/$defs/Jurisdiction"
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus"
        }
      }
    },
    "Claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "text",
        "citation_refs",
        "evidence_status",
        "limitations"
      ],
      "properties": {
        "claim_id": {
          "$ref": "#/$defs/Uuid"
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 3000
        },
        "citation_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Uuid"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus"
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "uniqueItems": true
        }
      }
    },
    "MissingEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gap_id",
        "subject",
        "missing_document",
        "reason",
        "next_documental_action"
      ],
      "properties": {
        "gap_id": {
          "$ref": "#/$defs/Uuid"
        },
        "subject": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "missing_document": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "reason": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "next_documental_action": {
          "$ref": "#/$defs/NonEmptyString"
        }
      }
    },
    "Contradiction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contradiction_id",
        "claim_refs",
        "description",
        "review_required"
      ],
      "properties": {
        "contradiction_id": {
          "$ref": "#/$defs/Uuid"
        },
        "claim_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Uuid"
          },
          "minItems": 2,
          "uniqueItems": true
        },
        "description": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "review_required": {
          "const": true
        }
      }
    },
    "DocumentReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_requirement_id",
        "name",
        "evidence_status",
        "citation_refs"
      ],
      "properties": {
        "document_requirement_id": {
          "$ref": "#/$defs/Uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus"
        },
        "citation_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Uuid"
          },
          "uniqueItems": true
        }
      }
    },
    "ProcedureStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "sequence",
        "action",
        "responsible_actor",
        "responsible_unit",
        "preconditions",
        "required_documents",
        "output_documents",
        "external_system",
        "approvals",
        "legal_basis",
        "citation_refs",
        "authority_status",
        "jurisdiction",
        "evidence_status",
        "confidence",
        "deadline",
        "completion_criteria",
        "follow_up_cadence",
        "risks",
        "unknowns"
      ],
      "properties": {
        "step_id": {
          "$ref": "#/$defs/Uuid"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "action": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "responsible_actor": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 300
        },
        "responsible_unit": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 300
        },
        "preconditions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NonEmptyString"
          },
          "uniqueItems": true
        },
        "required_documents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DocumentReference"
          },
          "uniqueItems": true
        },
        "output_documents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NonEmptyString"
          },
          "uniqueItems": true
        },
        "external_system": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 300
        },
        "approvals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NonEmptyString"
          },
          "uniqueItems": true
        },
        "legal_basis": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Uuid"
          },
          "uniqueItems": true
        },
        "citation_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Uuid"
          },
          "uniqueItems": true
        },
        "authority_status": {
          "$ref": "#/$defs/AuthorityStatus"
        },
        "jurisdiction": {
          "$ref": "#/$defs/Jurisdiction"
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "deadline": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        },
        "completion_criteria": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NonEmptyString"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "follow_up_cadence": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        },
        "risks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NonEmptyString"
          },
          "uniqueItems": true
        },
        "unknowns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NonEmptyString"
          },
          "uniqueItems": true
        }
      }
    },
    "ProcedureDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_step_id",
        "to_step_id",
        "dependency_type"
      ],
      "properties": {
        "from_step_id": {
          "$ref": "#/$defs/Uuid"
        },
        "to_step_id": {
          "$ref": "#/$defs/Uuid"
        },
        "dependency_type": {
          "type": "string",
          "enum": [
            "precondition",
            "document",
            "decision"
          ]
        }
      }
    },
    "DecisionGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "step_id",
        "question",
        "outcomes"
      ],
      "properties": {
        "gate_id": {
          "$ref": "#/$defs/Uuid"
        },
        "step_id": {
          "$ref": "#/$defs/Uuid"
        },
        "question": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "outcomes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "outcome",
              "next_step_id"
            ],
            "properties": {
              "outcome": {
                "$ref": "#/$defs/NonEmptyString"
              },
              "next_step_id": {
                "oneOf": [
                  {
                    "$ref": "#/$defs/Uuid"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            }
          },
          "minItems": 2
        }
      }
    },
    "Gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gap_id",
        "description",
        "severity",
        "next_documental_action"
      ],
      "properties": {
        "gap_id": {
          "$ref": "#/$defs/Uuid"
        },
        "description": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "severity": {
          "type": "string",
          "enum": [
            "blocking",
            "important",
            "informational"
          ]
        },
        "next_documental_action": {
          "$ref": "#/$defs/NonEmptyString"
        }
      }
    },
    "CaseContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_reference",
        "community_id",
        "facts",
        "provided_documents",
        "constraints"
      ],
      "properties": {
        "subject_reference": {
          "$ref": "#/$defs/SafeOpaqueId"
        },
        "community_id": {
          "$ref": "#/$defs/SafeOpaqueId"
        },
        "facts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NonEmptyString"
          },
          "uniqueItems": true
        },
        "provided_documents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SafeOpaqueId"
          },
          "uniqueItems": true
        },
        "constraints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NonEmptyString"
          },
          "uniqueItems": true
        }
      }
    },
    "ErrorDetail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "issue"
      ],
      "properties": {
        "field": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "issue": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    }
  }
}
