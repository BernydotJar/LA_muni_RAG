{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.la-muni-rag.invalid/v1/source-response.schema.json",
  "title": "SourceResponse v1",
  "$defs": {
    "SourceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_key", "title", "category", "target_jurisdiction", "source_jurisdiction", "source_relation", "discovery_status", "discovery_url", "artifact_url", "observed_version", "publication_date", "effective_date", "limitations", "validation_state", "official_source", "official_for_target_jurisdiction", "acquisition_state", "ingestion_state", "retrieval_state", "created_by_principal_id", "created_at", "updated_at"],
      "properties": {
        "source_id": { "$ref": "common.schema.json#/$defs/Uuid" },
        "source_key": { "type": "string", "minLength": 3, "maxLength": 128, "pattern": "^[a-z0-9][a-z0-9._:-]*$" },
        "title": { "type": "string", "minLength": 1, "maxLength": 500 },
        "category": { "type": "string", "enum": ["constitution", "national_law", "national_regulation", "planning", "budget", "organization", "procedure_manual", "function_manual", "council_record", "form", "community_record", "public_portal", "other"] },
        "target_jurisdiction": { "type": "string", "minLength": 2, "maxLength": 500 },
        "source_jurisdiction": { "type": "string", "minLength": 2, "maxLength": 500 },
        "source_relation": { "type": "string", "enum": ["target", "national", "comparative", "unknown"] },
        "discovery_status": { "type": "string", "enum": ["identified", "access_blocked", "unverified", "missing_source"] },
        "discovery_url": { "oneOf": [{ "type": "string", "format": "uri", "pattern": "^https?://", "maxLength": 2048 }, { "type": "null" }] },
        "artifact_url": { "oneOf": [{ "type": "string", "format": "uri", "pattern": "^https?://", "maxLength": 2048 }, { "type": "null" }] },
        "observed_version": { "type": ["string", "null"], "minLength": 1, "maxLength": 200 },
        "publication_date": { "oneOf": [{ "type": "string", "format": "date" }, { "type": "null" }] },
        "effective_date": { "oneOf": [{ "type": "string", "format": "date" }, { "type": "null" }] },
        "limitations": { "type": "array", "maxItems": 17, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
        "validation_state": { "type": "string", "enum": ["unreviewed", "review_required", "validated", "rejected"] },
        "official_source": { "type": "boolean" },
        "official_for_target_jurisdiction": { "type": "boolean" },
        "acquisition_state": { "type": "string", "enum": ["not_acquired", "acquisition_pending", "acquired", "access_blocked", "failed"] },
        "ingestion_state": { "type": "string", "enum": ["not_ingested", "ingestion_pending", "ingested", "failed"] },
        "retrieval_state": { "type": "string", "enum": ["not_indexed", "indexing", "indexed", "failed"] },
        "created_by_principal_id": { "$ref": "common.schema.json#/$defs/Uuid" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "response_type", "request_id", "tenant_id", "source", "provenance"],
  "properties": {
    "schema_version": { "$ref": "common.schema.json#/$defs/SchemaVersion" },
    "response_type": { "const": "source_catalog_item" },
    "request_id": { "$ref": "common.schema.json#/$defs/Uuid" },
    "tenant_id": { "$ref": "common.schema.json#/$defs/Uuid" },
    "source": { "$ref": "#/$defs/SourceItem" },
    "provenance": { "$ref": "common.schema.json#/$defs/Provenance" }
  }
}
