{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.la-muni-rag.invalid/staging/v1/ephemeral-staging-receipt.schema.json",
  "title": "Ephemeral staging execution receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "run_id", "plan_version", "git_sha", "status",
    "started_at", "finished_at", "phases", "journeys", "browser", "cleanup"
  ],
  "properties": {
    "schema_version": { "const": "v1" },
    "run_id": { "type": "string", "format": "uuid" },
    "plan_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "git_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "status": { "type": "string", "enum": ["passed", "failed"] },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "phases": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "preflight", "create_environment", "migrate_database", "seed_identity",
              "seed_domain_fixtures", "verify_api_system_journeys",
              "assert_browser_blockers", "collect_sanitized_artifacts", "destroy_environment"
            ]
          },
          "status": { "type": "string", "enum": ["passed", "failed", "not_run"] }
        }
      }
    },
    "journeys": {
      "type": "array",
      "minItems": 20,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "verified_by"],
        "properties": {
          "id": { "type": "string", "pattern": "^api-[a-z0-9-]{3,127}$" },
          "status": { "type": "string", "enum": ["passed", "failed", "not_run"] },
          "verified_by": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" }
        }
      }
    },
    "browser": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "blocked", "blocker_ids"],
      "properties": {
        "total": { "const": 12 },
        "blocked": { "const": 12 },
        "blocker_ids": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^BLK-[A-Z0-9-]{3,63}$" }
        }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["databases_destroyed", "roles_destroyed", "complete"],
      "properties": {
        "databases_destroyed": { "type": "integer", "minimum": 0, "maximum": 4 },
        "roles_destroyed": { "type": "integer", "minimum": 0, "maximum": 3 },
        "complete": { "type": "boolean" }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "subject", "code"],
      "properties": {
        "phase": { "type": "string", "minLength": 3, "maxLength": 64 },
        "subject": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{2,127}$" },
        "code": { "type": "string", "pattern": "^[a-z][a-z0-9_]{0,63}$" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "failed" } }, "required": ["status"] },
      "then": { "required": ["failure"] },
      "else": { "not": { "required": ["failure"] } }
    }
  ]
}
