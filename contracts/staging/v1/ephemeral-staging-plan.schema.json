{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.la-muni-rag.invalid/staging/v1/ephemeral-staging-plan.schema.json",
  "title": "LA Muni RAG ephemeral staging and E2E architecture plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_version",
    "environment",
    "identity",
    "tenants",
    "principals",
    "role_matrix",
    "fixtures",
    "reset",
    "journeys",
    "mocks",
    "layer_policy",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "plan_version": {
      "$ref": "#/$defs/SemVer"
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "isolation",
        "ttl_minutes",
        "destroy_after_run",
        "production_credentials_allowed",
        "production_data_allowed",
        "network_mode",
        "database_strategy",
        "browser_e2e_enabled"
      ],
      "properties": {
        "kind": {
          "const": "ephemeral_staging"
        },
        "isolation": {
          "const": "per_run"
        },
        "ttl_minutes": {
          "type": "integer",
          "minimum": 15,
          "maximum": 720
        },
        "destroy_after_run": {
          "const": true
        },
        "production_credentials_allowed": {
          "const": false
        },
        "production_data_allowed": {
          "const": false
        },
        "network_mode": {
          "enum": [
            "loopback_only",
            "isolated_allowlist"
          ]
        },
        "database_strategy": {
          "enum": [
            "fresh_database_per_run",
            "fresh_schema_per_run"
          ]
        },
        "browser_e2e_enabled": {
          "const": false
        }
      }
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "browser_session_status",
        "credential_material_source",
        "raw_secrets_in_manifest",
        "secret_persistence",
        "browser_blocker_ids"
      ],
      "properties": {
        "strategy": {
          "const": "service_credentials_only_until_human_idp_approved"
        },
        "browser_session_status": {
          "const": "blocked_pending_human_idp_bff"
        },
        "credential_material_source": {
          "const": "runtime_injected_ephemeral"
        },
        "raw_secrets_in_manifest": {
          "const": false
        },
        "secret_persistence": {
          "const": "forbidden"
        },
        "browser_blocker_ids": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/SafeId"
          }
        }
      }
    },
    "tenants": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "slug",
          "classification",
          "authoritative"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/Uuid"
          },
          "slug": {
            "$ref": "#/$defs/SafeId"
          },
          "classification": {
            "const": "synthetic_test"
          },
          "authoritative": {
            "const": false
          }
        }
      }
    },
    "principals": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "key",
          "tenant_id",
          "roles",
          "credential_ref",
          "credential_kind",
          "surface"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/Uuid"
          },
          "key": {
            "$ref": "#/$defs/SafeId"
          },
          "tenant_id": {
            "$ref": "#/$defs/Uuid"
          },
          "roles": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/Role"
            }
          },
          "credential_ref": {
            "$ref": "#/$defs/SafeId"
          },
          "credential_kind": {
            "const": "ephemeral_bearer_digest_reference"
          },
          "surface": {
            "enum": [
              "api",
              "api_and_planned_browser"
            ]
          }
        }
      }
    },
    "role_matrix": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "permissions",
          "api_required",
          "browser_required"
        ],
        "properties": {
          "role": {
            "$ref": "#/$defs/Role"
          },
          "permissions": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/Permission"
            }
          },
          "api_required": {
            "type": "boolean"
          },
          "browser_required": {
            "type": "boolean"
          }
        }
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "key",
          "tenant_id",
          "resource_type",
          "mutability",
          "synthetic",
          "authoritative"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/Uuid"
          },
          "key": {
            "$ref": "#/$defs/SafeId"
          },
          "tenant_id": {
            "$ref": "#/$defs/Uuid"
          },
          "resource_type": {
            "enum": [
              "source",
              "document",
              "ingestion_job",
              "evidence_bundle",
              "workflow_version",
              "procedure_case",
              "evidence_gap",
              "claim_pack",
              "audit_event"
            ]
          },
          "mutability": {
            "enum": [
              "mutable",
              "immutable_snapshot"
            ]
          },
          "synthetic": {
            "const": true
          },
          "authoritative": {
            "const": false
          }
        }
      }
    },
    "reset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "steps",
        "mutable_resource_types",
        "postconditions"
      ],
      "properties": {
        "mode": {
          "const": "recreate_and_verify_empty"
        },
        "steps": {
          "type": "array",
          "minItems": 10,
          "maxItems": 10,
          "uniqueItems": true,
          "items": {
            "enum": [
              "preflight_no_production_inputs",
              "create_isolated_database",
              "apply_migrations",
              "seed_identity",
              "seed_domain_fixtures",
              "verify_tenant_isolation",
              "run_api_system_journeys",
              "assert_browser_blockers",
              "collect_sanitized_artifacts",
              "destroy_environment"
            ]
          }
        },
        "mutable_resource_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "source",
              "document",
              "ingestion_job",
              "procedure_case",
              "audit_event"
            ]
          }
        },
        "postconditions": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "no_cross_tenant_rows",
              "no_raw_credentials",
              "no_orphan_artifacts",
              "database_destroyed",
              "sanitized_artifacts_only"
            ]
          }
        }
      }
    },
    "journeys": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "layer",
          "status",
          "actor_principal_id",
          "method",
          "route",
          "concerns",
          "expected_statuses",
          "blocker_ids",
          "auth_mode",
          "required_permission",
          "permission_expectation"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/SafeId"
          },
          "layer": {
            "enum": [
              "api",
              "browser"
            ]
          },
          "status": {
            "enum": [
              "runnable",
              "blocked"
            ]
          },
          "actor_principal_id": {
            "$ref": "#/$defs/Uuid"
          },
          "target_tenant_id": {
            "$ref": "#/$defs/Uuid"
          },
          "method": {
            "enum": [
              "GET",
              "POST",
              "PATCH"
            ]
          },
          "route": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240,
            "pattern": "^/"
          },
          "concerns": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/Concern"
            }
          },
          "expected_statuses": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "integer",
              "minimum": 200,
              "maximum": 599
            }
          },
          "blocker_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/SafeId"
            }
          },
          "auth_mode": {
            "enum": [
              "authenticated",
              "credential_omitted"
            ]
          },
          "required_permission": {
            "oneOf": [
              {
                "$ref": "#/$defs/Permission"
              },
              {
                "type": "null"
              }
            ]
          },
          "permission_expectation": {
            "enum": [
              "allow",
              "deny",
              "not_applicable"
            ]
          }
        }
      }
    },
    "mocks": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "mode",
          "endpoint",
          "verification_status",
          "external_verification_claimed",
          "production_equivalent"
        ],
        "properties": {
          "target": {
            "enum": [
              "query_embedding_provider",
              "object_storage",
              "malware_scanner",
              "os_electoral",
              "content_agency",
              "human_idp"
            ]
          },
          "mode": {
            "enum": [
              "deterministic_local_stub",
              "boundary_stub_only",
              "contract_stub_only",
              "not_implemented_blocker"
            ]
          },
          "endpoint": {
            "oneOf": [
              {
                "type": "string",
                "format": "uri"
              },
              {
                "type": "null"
              }
            ]
          },
          "verification_status": {
            "enum": [
              "local_stub",
              "provider_contract_only",
              "not_implemented",
              "externally_verified"
            ]
          },
          "external_verification_claimed": {
            "type": "boolean"
          },
          "production_equivalent": {
            "const": false
          }
        }
      }
    },
    "layer_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "api_owned_concerns",
        "browser_owned_concerns",
        "browser_prerequisites",
        "browser_suite_budget"
      ],
      "properties": {
        "api_owned_concerns": {
          "type": "array",
          "minItems": 8,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/Concern"
          }
        },
        "browser_owned_concerns": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/Concern"
          }
        },
        "browser_prerequisites": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "human_idp_decision",
              "bff_session_implementation",
              "deterministic_fixtures",
              "ephemeral_services_deployed",
              "role_aware_ui",
              "csrf_and_logout"
            ]
          }
        },
        "browser_suite_budget": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 10,
        "maxLength": 1000
      }
    }
  },
  "$defs": {
    "Uuid": {
      "type": "string",
      "format": "uuid"
    },
    "SafeId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "SemVer": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "Role": {
      "enum": [
        "platform_admin",
        "tenant_admin",
        "document_manager",
        "researcher",
        "procedure_author",
        "procedure_reviewer",
        "procedure_approver",
        "case_operator",
        "viewer",
        "integration_client"
      ]
    },
    "Permission": {
      "enum": [
        "platform:admin",
        "tenant:manage",
        "identity:manage",
        "source:read",
        "source:write",
        "document:read",
        "document:write",
        "document:ingest",
        "evidence:query",
        "procedure:read",
        "procedure:draft",
        "procedure:review",
        "procedure:approve",
        "case:read",
        "case:write",
        "audit:read",
        "integration:query"
      ]
    },
    "Concern": {
      "enum": [
        "schema_validation",
        "authentication_header",
        "authorization",
        "tenant_isolation",
        "rls",
        "idempotency",
        "replay_conflict",
        "persistence",
        "provider_failure",
        "contract_boundary",
        "reset_integrity",
        "separation_of_duties",
        "session_cookie",
        "csrf",
        "role_navigation",
        "user_feedback",
        "accessibility",
        "critical_journey"
      ]
    }
  }
}
