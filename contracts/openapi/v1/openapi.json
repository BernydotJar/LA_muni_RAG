{
  "openapi": "3.1.1",
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "info": {
    "title": "LA Muni RAG v1 API Contract",
    "version": "1.0.0",
    "description": "Contract for the implemented evidence-bundle and procedure-workflow providers plus authenticated ingestion-job submission/status slices. ProcedureAssessment, document upload, and a deployed worker/storage/scanner remain unavailable; this document does not claim deployment."
  },
  "x-implementation-status": "claim_pack_evidence_bundle_procedure_workflow_and_ingestion_job_providers_implemented_with_limits",
  "paths": {
    "/api/v1/claim-packs": {
      "post": {
        "operationId": "submitClaimPack",
        "summary": "Request a citation-preserving ClaimPack",
        "description": "Accepts a tenant-scoped Content Agency ClaimPackRequest. LA Muni RAG returns claims, citations, paraphrase limits, disclaimer, validity bound, and source links only; it does not generate copy, assets, channel plans, publication tasks, or campaign strategy.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "description": "Stable key for safely replaying the same tenant-scoped request.",
            "schema": {
              "type": "string",
              "minLength": 16,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{15,127}$"
            }
          },
          {
            "name": "X-Request-Id",
            "in": "header",
            "required": true,
            "description": "UUID that must equal request_id in the body.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../../schemas/v1/claim-pack-request.schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contract-valid ClaimPack with at least one citable supported or comparative claim.",
            "headers": {
              "X-Request-Id": {
                "$ref": "#/components/headers/RequestId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/v1/claim-pack.schema.json"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/v1/procedure-queries": {
      "post": {
        "operationId": "submitProcedureQuery",
        "summary": "Request evidence-backed procedural intelligence",
        "description": "Accepts a tenant-scoped ProcedureQueryRequest. LA Muni RAG returns evidence or procedural artifacts only; it does not return campaign strategy or generate content.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "description": "Stable key for safely replaying the same tenant-scoped request.",
            "schema": {
              "type": "string",
              "minLength": 16,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{15,127}$"
            }
          },
          {
            "name": "X-Request-Id",
            "in": "header",
            "required": true,
            "description": "UUID that must equal request_id in the body.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../../schemas/v1/procedure-query-request.schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contract-valid EvidenceBundle or draft ProcedureWorkflow response. ProcedureAssessment currently returns 503 capability_unavailable.",
            "headers": {
              "X-Request-Id": {
                "$ref": "#/components/headers/RequestId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "../../schemas/v1/evidence-bundle.schema.json"
                    },
                    {
                      "$ref": "../../schemas/v1/procedure-workflow.schema.json"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        }
      }
    },
    "/api/v1/ingestion-jobs": {
      "post": {
        "operationId": "enqueueIngestionJob",
        "summary": "Enqueue an already accepted document version for ingestion",
        "description": "Requires an existing tenant-owned document version whose persisted content digest matches the request. This operation does not upload bytes or assert scanner/storage acceptance.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "description": "Stable key for safely replaying the same principal-scoped ingestion request.",
            "schema": {
              "type": "string",
              "minLength": 16,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{15,127}$"
            }
          },
          {
            "name": "X-Request-Id",
            "in": "header",
            "required": true,
            "description": "UUID that must equal request_id in the body.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../../schemas/v1/ingestion-job-request.schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Exact idempotent replay of an existing ingestion job.",
            "headers": {
              "X-Request-Id": {
                "$ref": "#/components/headers/RequestId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/v1/ingestion-job-response.schema.json"
                }
              }
            }
          },
          "202": {
            "description": "A new job was queued or equivalent tenant work was deduplicated.",
            "headers": {
              "X-Request-Id": {
                "$ref": "#/components/headers/RequestId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/v1/ingestion-job-response.schema.json"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        }
      }
    },
    "/api/v1/ingestion-jobs/{job_id}": {
      "get": {
        "operationId": "getIngestionJob",
        "summary": "Read tenant-scoped ingestion job status",
        "description": "Returns status only for a job visible to the authenticated tenant. Missing and cross-tenant identifiers share the same non-leaking 404 response.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "X-Request-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tenant-scoped ingestion job status.",
            "headers": {
              "X-Request-Id": {
                "$ref": "#/components/headers/RequestId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/v1/ingestion-job-response.schema.json"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Tenant-scoped service, integration, or operator credential. Authorization remains operation-specific."
      }
    },
    "headers": {
      "RequestId": {
        "description": "Request correlation UUID.",
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "RetryAfter": {
        "description": "Seconds before a retry is allowed.",
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      },
      "WWWAuthenticate": {
        "description": "Bearer authentication challenge.",
        "schema": {
          "type": "string",
          "const": "Bearer realm=\"la-muni-rag\""
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "The request failed schema or semantic validation.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../../schemas/v1/api-error.schema.json"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Bearer authentication is missing or invalid.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          },
          "WWW-Authenticate": {
            "$ref": "#/components/headers/WWWAuthenticate"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../../schemas/v1/api-error.schema.json"
            }
          }
        }
      },
      "Forbidden": {
        "description": "The credential cannot access the requested tenant or resource.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../../schemas/v1/api-error.schema.json"
            }
          }
        }
      },
      "NotFound": {
        "description": "The tenant-scoped resource was not found; no cross-tenant existence information is returned.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../../schemas/v1/api-error.schema.json"
            }
          }
        }
      },
      "Conflict": {
        "description": "The idempotency key or referenced version conflicts with existing state.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../../schemas/v1/api-error.schema.json"
            }
          }
        }
      },
      "RateLimited": {
        "description": "The tenant or credential rate limit was exceeded.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          },
          "Retry-After": {
            "$ref": "#/components/headers/RetryAfter"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../../schemas/v1/api-error.schema.json"
            }
          }
        }
      },
      "InternalError": {
        "description": "An internal error occurred without exposing sensitive details.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../../schemas/v1/api-error.schema.json"
            }
          }
        }
      },
      "Unavailable": {
        "description": "The requested contract capability or a required dependency is unavailable.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          },
          "Retry-After": {
            "$ref": "#/components/headers/RetryAfter"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../../schemas/v1/api-error.schema.json"
            }
          }
        }
      }
    }
  }
}
