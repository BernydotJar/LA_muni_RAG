{
  "name": "la_muni_rag",
  "version": "1.0.0",
  "description": "Production-grade RAG agent foundation for La Antigua Guatemala municipal documents.",
  "main": "dist/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:pages": "node scripts/build-pages.mjs",
    "contracts:validate": "node --import tsx src/cli/validateIntegrationContracts.ts",
    "dev:api": "tsx watch src/server.ts",
    "dev:start": "node scripts/dev-start.mjs",
    "document-library": "node --import tsx src/cli/documentLibrary.ts",
    "domain:evaluate": "node --import tsx src/cli/evaluateDomainPacks.ts",
    "domain:init": "tsx src/cli/initDomainPack.ts",
    "eval:boundary": "node --import tsx --test src/__tests__/eval-boundary-001.test.ts",
    "eval:conflict": "node --import tsx --test src/__tests__/eval-conflict-001.test.ts",
    "eval:content-integration": "node --import tsx --test src/__tests__/eval-content-integration-001.test.ts",
    "eval:corrupt": "node --import tsx --test src/__tests__/eval-corrupt-001.test.ts src/__tests__/ingestion-pdf.test.ts src/__tests__/ingestion-worker.test.ts src/__tests__/ingestion-job-service.test.ts",
    "eval:mixco": "node --import tsx --test src/__tests__/eval-mixco-001.test.ts",
    "eval:os-integration": "node --import tsx --test src/__tests__/eval-os-integration-001.test.ts",
    "eval:procedure": "node --import tsx --test src/__tests__/eval-procedure-001.test.ts",
    "eval:tenant": "node --import tsx --test src/__tests__/eval-tenant-001.test.ts",
    "eval:water": "node --import tsx --test src/__tests__/eval-water-001.test.ts",
    "ports:kill": "node scripts/kill-ports.mjs",
    "search": "tsx src/cli/search.ts",
    "smoke:claim-pack": "node scripts/claim-pack-postgres-smoke.mjs",
    "smoke:ingestion-api": "node scripts/ingestion-api-postgres-smoke.mjs",
    "smoke:postgres-api": "node scripts/procedure-query-postgres-smoke.mjs",
    "smoke:tenant-ingestion": "node scripts/tenant-ingestion-postgres-smoke.mjs",
    "smoke:workflow-lifecycle": "node scripts/workflow-lifecycle-postgres-smoke.mjs",
    "source-inventory:validate": "node --import tsx src/cli/validateSourceInventory.ts --manifest .rag/source-inventory.json",
    "start": "node dist/server.js",
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "test:workflow-lifecycle": "node --import tsx --test src/__tests__/workflow-lifecycle-state-machine.test.ts src/__tests__/workflow-lifecycle-migration.test.ts src/__tests__/workflow-lifecycle-api-migration.test.ts src/__tests__/workflow-lifecycle-api-v1.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "workflow:validate": "tsx src/cli/validateWorkflowTemplate.ts",
    "eval:artifact": "node --import tsx --test src/__tests__/eval-artifact-001.test.ts src/__tests__/artifact-vector-runtime-hardening-migration.test.ts",
    "eval:vector": "node --import tsx --test src/__tests__/eval-vector-001.test.ts src/__tests__/tenant-pg-vector-repository.test.ts",
    "eval:job-lease": "node --import tsx --test src/__tests__/eval-job-lease-001.test.ts src/__tests__/ingestion-job-service.test.ts src/__tests__/ingestion-worker.test.ts",
    "eval:assessment": "node --import tsx --test src/__tests__/eval-procedure-assessment-001.test.ts",
    "eval:evidence-gap": "node --import tsx --test src/__tests__/eval-evidence-gap-001.test.ts src/__tests__/evidence-gap-runtime-migration.test.ts",
    "smoke:evidence-gap": "node scripts/evidence-gap-postgres-smoke.mjs",
    "eval:accessibility": "node --import tsx --test src/__tests__/procedure-training-console.test.ts src/__tests__/eval-accessibility-001.test.ts",
    "test:procedure-case": "node --import tsx --test src/__tests__/procedure-case-api-v1.test.ts src/__tests__/procedure-case-runtime-migration.test.ts",
    "eval:case": "node --import tsx --test src/__tests__/eval-case-001.test.ts src/__tests__/procedure-case-api-v1.test.ts src/__tests__/procedure-case-runtime-migration.test.ts",
    "smoke:procedure-case": "node scripts/procedure-case-postgres-smoke.mjs",
    "eval:restore": "node --import tsx --test src/__tests__/eval-restore-001.test.ts",
    "smoke:restore": "node scripts/postgres-restore-drill.mjs",
    "eval:source": "node --import tsx --test src/__tests__/eval-source-001.test.ts src/__tests__/source-inventory.test.ts src/__tests__/source-inventory-domain-metadata.test.ts src/__tests__/source-inventory-missing.test.ts src/__tests__/source-inventory-acquisition.test.ts src/__tests__/source-authority-freshness.test.ts",
    "eval:missing": "node --import tsx --test src/__tests__/eval-missing-001.test.ts src/__tests__/procedure-query-mapper-v1.test.ts src/__tests__/procedure-query-api-v1.test.ts src/__tests__/evidence-gap-api-v1.test.ts",
    "eval:rbac": "node --import tsx --test src/__tests__/eval-rbac-001.test.ts src/__tests__/identity-tenancy-rbac.test.ts src/__tests__/tenant-ingestion-runtime-migration.test.ts src/__tests__/procedure-case-api-v1.test.ts",
    "eval:ingest": "node --import tsx --test src/__tests__/eval-ingest-001.test.ts src/__tests__/eval-artifact-001.test.ts src/__tests__/eval-vector-001.test.ts src/__tests__/eval-job-lease-001.test.ts src/__tests__/ingestion-job-api-v1.test.ts src/__tests__/ingestion-job-service.test.ts src/__tests__/ingestion-worker.test.ts src/__tests__/tenant-ingestion-runtime-migration.test.ts",
    "eval:source-api": "node --import tsx --test src/__tests__/eval-source-api-001.test.ts src/__tests__/catalog-api-v1.test.ts src/__tests__/catalog-api-runtime-migration.test.ts",
    "eval:document-api": "node --import tsx --test src/__tests__/eval-document-api-001.test.ts src/__tests__/catalog-api-v1.test.ts src/__tests__/catalog-api-runtime-migration.test.ts",
    "smoke:catalog-api": "node scripts/catalog-api-postgres-smoke.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "dependencies": {
    "@napi-rs/canvas": "1.0.2",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "dotenv": "^17.4.2",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "6.1.200",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
