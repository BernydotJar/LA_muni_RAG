DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/la_muni_rag

# Optional. Defaults to municipal-antigua.
# Supported: municipal-antigua, hr, finance, sales-sop, custom.
DOMAIN_PACK=municipal-antigua

# Required only to enable authenticated GET/POST /api/procedure-feedback.
# Use a long random secret and never expose it in public frontend assets.
PROCEDURE_FEEDBACK_API_TOKEN=replace-with-a-long-random-secret

# Document artifact safety gate. clamdscan is preferred for repeated scans;
# clamscan is supported for standalone environments. The runtime must provide
# the selected executable and current signature databases. Missing or failing
# scanners block extraction and quarantine the artifact.
DOCUMENT_MALWARE_SCANNER=clamdscan
# Optional: absolute executable and clamd config paths.
# DOCUMENT_MALWARE_SCANNER_COMMAND=/usr/bin/clamdscan
# DOCUMENT_MALWARE_SCANNER_CONFIG=/etc/clamav/clamd.conf
DOCUMENT_MAX_ARTIFACT_BYTES=104857600
DOCUMENT_MALWARE_SCAN_MAX_AGE_SECONDS=86400
DOCUMENT_MALWARE_SCAN_TIMEOUT_MS=120000

# Raw PDF extraction runs in a bounded child process only after a clean artifact
# safety decision. Values above the compiled hard ceilings are rejected.
PDF_EXTRACTION_MAX_INPUT_BYTES=67108864
PDF_EXTRACTION_TIMEOUT_MS=120000
PDF_EXTRACTION_MAX_PAGES=1000
PDF_EXTRACTION_MAX_PAGE_TEXT_BYTES=262144
PDF_EXTRACTION_MAX_TOTAL_TEXT_BYTES=8388608
PDF_EXTRACTION_MEMORY_MB=512
PDF_EXTRACTION_MAX_CONCURRENCY=1

# Public browser query gateway. Disabled by default. Enabling it requires one
# reviewed public tenant/corpus and exact browser origins. The HMAC secret is
# server-only and must never be exposed through GitHub Pages or JavaScript.
PUBLIC_QUERY_ENABLED=false
# PUBLIC_QUERY_TENANT_ID=00000000-0000-4000-8000-000000000000
# PUBLIC_QUERY_JURISDICTION=Municipio de La Antigua Guatemala, Sacatepéquez, Guatemala
# PUBLIC_QUERY_ALLOWED_ORIGINS=https://consulta.example
# PUBLIC_QUERY_RATE_LIMIT_SECRET=replace-with-at-least-32-random-characters
PUBLIC_QUERY_RATE_LIMIT=20
PUBLIC_QUERY_GLOBAL_RATE_LIMIT=100
PUBLIC_QUERY_RATE_WINDOW_SECONDS=60
PUBLIC_QUERY_MAX_RESULTS=5
